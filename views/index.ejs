<%- include('./partials/header') %>

    <% if(error && error.length > 0){ %>
        <div class="fixed top-20 left-1/2 -translate-x-1/2 z-50 p-4 rounded-lg bg-red-500 shadow-lg animate-fade-in">
            <span class="inline-block text-white font-medium">
                <%= Array.isArray(error) ? error[0] : error %>
            </span>
        </div>
    <% } %>

    <% if(success && success.length > 0){ %>
        <div class="fixed top-20 left-1/2 -translate-x-1/2 z-50 p-4 rounded-lg bg-green-500 shadow-lg animate-fade-in">
            <span class="inline-block text-white font-medium">
                <%= Array.isArray(success) ? success[0] : success %>
            </span>
        </div>
    <% } %>
    
    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden" style="background: linear-gradient(135deg, rgba(183, 110, 121, 0.85) 0%, rgba(30, 30, 30, 0.9) 100%), url('https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=1920') center/cover;">
        <div class="absolute inset-0" style="background-color: rgba(30, 30, 30, 0.4);"></div>
        <div class="relative z-10 container mx-auto px-4 text-center text-white">
            <h1 class="text-6xl md:text-8xl font-bold mb-6 brand-font" style="color: #B76E79;">
                URBAN ÉLITE
            </h1>
            <p class="text-xl md:text-2xl mb-8" style="color: #FAFAFA;">Premium Fashion & Lifestyle</p>
            <p class="text-lg md:text-xl mb-12 max-w-2xl mx-auto" style="color: #E5E5E5;">
                Discover elegance, quality, and style. Experience the finest collection of luxury products.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="/users/register" class="px-8 py-4 rounded-lg font-semibold transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5" style="background-color: #FAFAFA; color: #1E1E1E;" onmouseover="this.style.backgroundColor='#F0F0F0'" onmouseout="this.style.backgroundColor='#FAFAFA'">
                    Get Started
                </a>
                <a href="/users/login" class="px-8 py-4 rounded-lg border-2 font-semibold transition-all" style="border-color: #FAFAFA; color: #FAFAFA;" onmouseover="this.style.backgroundColor='#FAFAFA'; this.style.color='#1E1E1E';" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#FAFAFA';">
                    Sign In
                </a>
            </div>
        </div>
    </section>

    <!-- About Section -->
