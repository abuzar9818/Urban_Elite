                        <img src="/images/about-lifestyle.png" alt="Urban Elite Lifestyle" class="w-full h-auto object-cover">
                    </div>
                    <div class="absolute -bottom-6 -left-6 w-32 h-32 rounded-full flex items-center justify-center text-white text-center p-4 transform -rotate-12" style="background-color: #B76E79; border: 4px solid #FAFAFA;">
                        <span class="text-sm font-bold uppercase tracking-tighter">Est. 2024 Luxury Living</span>
                    </div>
                </div>
            </div>
