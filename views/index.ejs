                        <i class="ri-ruler-2-line text-2xl" style="color: #B76E79;"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-3" style="color: #1E1E1E;">Curated Collections</h3>
                    <p class="text-gray-600">Every item in our store is hand-selected by fashion experts for maximum style and quality.</p>
                </div>
                <div class="p-8 rounded-2xl transition-all duration-300 hover:shadow-xl hover:-translate-y-2" style="background-color: #FAFAFA; border: 1px solid #E5E5E5;">
                    <div class="w-14 h-14 rounded-xl flex items-center justify-center mb-6" style="background-color: rgba(183, 110, 121, 0.1);">
